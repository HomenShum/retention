# retention.sh Environment Variables
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────
# OpenAI API Key (required for LLM-as-judge verification)
OPENAI_API_KEY=sk-your-api-key-here

# ── CORS & Security ──────────────────────────────────────────
# Comma-separated list of allowed origins (defaults include localhost dev ports)
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Regex pattern for dynamic origins (defaults to Vercel preview URLs)
# ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# MCP authentication token (auto-generated to .claude/mcp-token if not set)
# RETENTION_MCP_TOKEN=your-token-here

# ── Optional Integrations ────────────────────────────────────
# Figma access token for design-to-test integration
FIGMA_ACCESS_TOKEN=

# LangSmith observability (optional)
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true

# ── Android / Device Testing ─────────────────────────────────
# Android SDK path (auto-detected if not set)
# ANDROID_HOME=/Users/yourusername/Library/Android/sdk
# Default device ID
# E2E_DEVICE_ID=emulator-5554

# ── Override (rarely needed) ─────────────────────────────────
# Override repo root detection
# TA_REPO_ROOT=/path/to/repo

